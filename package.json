{
  "name": "pando",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:fixture": "tsx prisma/fixtures/real-data.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "verify": "prisma validate && tsc --noEmit && npm run db:fixture",
    "verify:slice1": "tsx prisma/fixtures/slice1-catalogue.ts",
    "verify:slice2": "tsx prisma/fixtures/slice2-clients.ts",
    "mail:dev": "maildev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.7",
    "puppeteer": "^23.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "csv-parse": "^5.6.0",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "maildev": "^3.0.0-rc.1",
    "prisma": "6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
