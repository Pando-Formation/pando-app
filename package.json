{
  "name": "pando",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:fixture": "tsx prisma/fixtures/real-data.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "verify": "prisma validate && tsc --noEmit && npm run db:fixture",
    "verify:slice1": "tsx prisma/fixtures/slice1-catalogue.ts",
    "verify:slice2": "tsx prisma/fixtures/slice2-clients.ts",
    "verify:slice3": "tsx prisma/fixtures/slice3-formateurs.ts",
    "verify:slice4": "tsx prisma/fixtures/slice4-parcours.ts",
    "verify:slice5": "tsx prisma/fixtures/slice5-participants.ts",
    "verify:slice6": "tsx prisma/fixtures/slice6-documents.ts",
    "verify:slice7": "tsx prisma/fixtures/slice7-communication.ts",
    "verify:slice8": "tsx prisma/fixtures/slice8-attendance.ts",
    "verify:slice9": "tsx prisma/fixtures/slice9-amelioration.ts",
    "verify:slice10": "tsx prisma/fixtures/slice10-pilotage.ts",
    "mail:dev": "maildev"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@prisma/client": "6.19.3",
    "@tailwindcss/postcss": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "nodemailer": "^7.0.7",
    "postcss": "^8.5.17",
    "puppeteer": "^23.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "agentation": "^3.0.2",
    "csv-parse": "^5.6.0",
    "eslint": "^9",
    "eslint-config-next": "^15.1.6",
    "maildev": "^3.0.0-rc.1",
    "prisma": "6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
