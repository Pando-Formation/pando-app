# ── Database ────────────────────────────────────────────────────────────────
# Local:  docker run --name pando-db -e POSTGRES_PASSWORD=pando \
#           -e POSTGRES_DB=pando -p 5432:5432 -d postgres:16
DATABASE_URL="postgresql://postgres:pando@localhost:5432/pando"

# ── Auth ────────────────────────────────────────────────────────────────────
AUTH_SECRET=""                       # openssl rand -base64 32
AUTH_URL="http://localhost:3000"

# Admins: Google OAuth, restricted to this domain.
# NOTE: the domain is pando-formation.fr — NOT pando.fr.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
PANDO_DOMAIN="pando-formation.fr"

# Formateurs: magic link over SMTP.
# 🔴 External formateurs use gmail.com / their own domains.
#    They CANNOT use Google OAuth. This is not optional. See AGENTS.md.
EMAIL_SERVER_HOST="smtp-relay.brevo.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="no-reply@pando-formation.fr"

# ── Integrations (V1: not yet wired — slices 6 & 7) ──────────────────────────
BREVO_API_KEY=""
YOUSIGN_API_KEY=""
QONTO_API_KEY=""
INSEE_SIRENE_TOKEN=""                # free — https://api.insee.fr
